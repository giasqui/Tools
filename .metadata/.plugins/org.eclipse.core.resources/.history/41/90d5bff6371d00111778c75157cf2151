    private BigInteger cmToTwips(String cmValue) {
        try {
            double cm = Double.parseDouble(cmValue.replace(",", "."));
            return BigInteger.valueOf(Math.round((cm / 2.54) * 1440));
        } catch (Exception e) { return BigInteger.ZERO; }
    }

    private void setupEvents() {
        btnBrowse.addActionListener(e -> {
            JFileChooser chooser = new JFileChooser();
            chooser.setFileSelectionMode(JFileChooser.DIRECTORIES_ONLY);
            if (chooser.showOpenDialog(this) == JFileChooser.APPROVE_OPTION) {
                txtFilePath.setText(chooser.getSelectedFile().getAbsolutePath());
            }
        });
        btnCaptureArea.addActionListener(e -> new AreaSelector(true));
        btnCaptureClick.addActionListener(e -> new AreaSelector(false));
        btnStart.addActionListener(e -> startScanProcess());
    }

    private class AreaSelector extends JWindow {
        private Point startPoint;
        private boolean isAreaMode;

        public AreaSelector(boolean areaMode) {
            this.isAreaMode = areaMode;
            setBackground(new Color(0, 0, 0, 1));
            setSize(Toolkit.getDefaultToolkit().getScreenSize());
            setCursor(new Cursor(Cursor.CROSSHAIR_CURSOR));
            setAlwaysOnTop(true);
            addMouseListener(new MouseAdapter() {
                @Override
                public void mousePressed(MouseEvent e) {
                    if (isAreaMode) startPoint = e.getPoint();
                    else {
                        txtClickX.setText(String.valueOf(e.getX()));
                        txtClickY.setText(String.valueOf(e.getY()));
                        dispose();
                    }
                }
                @Override
                public void mouseReleased(MouseEvent e) {
                    if (isAreaMode && startPoint != null) {
                        txtX1.setText(String.valueOf(Math.min(startPoint.x, e.getX())));
                        txtY1.setText(String.valueOf(Math.min(startPoint.y, e.getY())));
                        txtX2.setText(String.valueOf(Math.max(startPoint.x, e.getX())));
                        txtY2.setText(String.valueOf(Math.max(startPoint.y, e.getY())));
                        dispose();
                    }
                }
            });
            if (isAreaMode) addMouseMotionListener(new MouseMotionAdapter() {
                @Override public void mouseDragged(MouseEvent e) { repaint(); }
            });
            setVisible(true);
        }

        @Override
        public void paint(Graphics g) {
            super.paint(g);
            if (isAreaMode && startPoint != null) {
                Point current = MouseInfo.getPointerInfo().getLocation();
                SwingUtilities.convertPointFromScreen(current, this);
                Graphics2D g2d = (Graphics2D) g;
                g2d.setColor(new Color(0, 120, 215, 60));
                int x = Math.min(startPoint.x, current.x);
                int y = Math.min(startPoint.y, current.y);
                int w = Math.abs(startPoint.x - current.x);
                int h = Math.abs(startPoint.y - current.y);
                g2d.fillRect(x, y, w, h);
                g2d.setColor(new Color(0, 120, 215));
                g2d.drawRect(x, y, w, h);
            }
        }
    }

    private void startScanProcess() {
        String filePath = txtFilePath.getText();
        String fileName = txtFileName.getText();
        final int pages, sX, sY, w, h, cX, cY;
        final BigInteger mT = cmToTwips(txtMarginTop.getText()), mB = cmToTwips(txtMarginBottom.getText()), 
                           mL = cmToTwips(txtMarginLeft.getText()), mR = cmToTwips(txtMarginRight.getText());

        try {
            pages = Integer.parseInt(txtPages.getText());
            int x1 = Integer.parseInt(txtX1.getText()), y1 = Integer.parseInt(txtY1.getText());
            int x2 = Integer.parseInt(txtX2.getText()), y2 = Integer.parseInt(txtY2.getText());
            sX = x1; sY = y1; w = x2 - x1; h = y2 - y1;
            cX = Integer.parseInt(txtClickX.getText()); cY = Integer.parseInt(txtClickY.getText());
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Dati numerici non validi!");
            return;
        }

        btnStart.setEnabled(false);
        new SwingWorker<Void, String>() {
            @Override
            protected Void doInBackground() throws Exception {
                publish("Avvio in 5 secondi...");
                Robot robot = new Robot();
                XWPFDocument doc = new XWPFDocument();
                CTSectPr sectPr = doc.getDocument().getBody().addNewSectPr();
                CTPageMar pageMar = sectPr.addNewPgMar();
                pageMar.setTop(mT); pageMar.setBottom(mB); pageMar.setLeft(mL); pageMar.setRight(mR);

                File dir = new File(filePath); if (!dir.exists()) dir.mkdirs();
                File psDir = new File(dir, "printscreen"); if (!psDir.exists()) psDir.mkdirs();

                Thread.sleep(5000);
                Rectangle rect = new Rectangle(sX, sY, w, h);

                for (int i = 0; i < pages; i++) {
                    publish("Pagina " + (i + 1));
                    BufferedImage img = robot.createScreenCapture(rect);
                    File imgFile = new File(psDir, TimeStamp.timeStamp() + "_p" + (i + 1) + ".jpg");
                    ImageIO.write(img, "jpg", imgFile);

                    robot.mouseMove(cX, cY);
                    robot.mousePress(java.awt.event.InputEvent.BUTTON1_DOWN_MASK);
                    robot.mouseRelease(java.awt.event.InputEvent.BUTTON1_DOWN_MASK);

                    XWPFParagraph para = doc.createParagraph();
                    para.setAlignment(org.apache.poi.xwpf.usermodel.ParagraphAlignment.CENTER);
                    XWPFRun run = para.createRun();
                    try (FileInputStream is = new FileInputStream(imgFile)) {
                        // Inserimento 1:1 Pixel -> EMU per preservare qualità OCR
                        run.addPicture(is, XWPFDocument.PICTURE_TYPE_JPEG, imgFile.getName(), 
                                       Units.toEMU(w), Units.toEMU(h));
                    }
                    Thread.sleep(1500);
                }
                try (FileOutputStream out = new FileOutputStream(new File(dir, fileName + ".docx"))) { doc.write(out); }
                return null;
            }
            @Override protected void process(java.util.List<String> chunks) { for (String m : chunks) logArea.append(m + "\n"); }
            @Override protected void done() {
                logArea.append("Completato.\n");
                btnStart.setEnabled(true);
                JOptionPane.showMessageDialog(null, "Documento creato!");
            }
        }.execute();
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new SmartScanGUI().setVisible(true));
    }
