package it.giasqui;

import javax.swing.*;
import java.awt.*;
import java.awt.event.MouseAdapter;
import java.awt.event.MouseEvent;
import java.awt.event.MouseMotionAdapter;
import java.awt.image.BufferedImage;
import java.io.File;
import java.io.FileInputStream;
import java.io.FileOutputStream;
import javax.imageio.ImageIO;
import java.math.BigInteger;

import org.apache.poi.xwpf.usermodel.XWPFDocument;
import org.apache.poi.xwpf.usermodel.XWPFParagraph;
import org.apache.poi.xwpf.usermodel.XWPFRun;
import org.apache.poi.util.Units;
import org.openxmlformats.schemas.wordprocessingml.x2006.main.CTPageMar;
import org.openxmlformats.schemas.wordprocessingml.x2006.main.CTSectPr;

import it.giasqui.timestamp.TimeStamp;

public class SmartScanGUI extends JFrame {

    private JTextField txtFilePath, txtFileName, txtPages, txtX1, txtY1, txtX2, txtY2;
    private JButton btnBrowse, btnCapture, btnStart;
    private JTextArea logArea;

    public SmartScanGUI() {
        setTitle("SmartScan Pro - v1.2");
        setSize(550, 750);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLayout(new BorderLayout(10, 10));

        JPanel inputPanel = new JPanel(new GridLayout(8, 2, 5, 5));
        inputPanel.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));

        inputPanel.add(new JLabel("Cartella Destinazione:"));
        txtFilePath = new JTextField();
        inputPanel.add(txtFilePath);

        btnBrowse = new JButton("Sfoglia...");
        inputPanel.add(new JLabel("")); 
        inputPanel.add(btnBrowse);

        inputPanel.add(new JLabel("Nome File (senza estensione):"));
        txtFileName = new JTextField("Scansione_" + TimeStamp.timeStamp());
        inputPanel.add(txtFileName);

        inputPanel.add(new JLabel("Numero Pagine:"));
        txtPages = new JTextField("3");
        inputPanel.add(txtPages);

        inputPanel.add(new JLabel("Vertice Sup SX (X, Y):"));
        JPanel coordPanel1 = new JPanel(new GridLayout(1, 2, 5, 5));
        txtX1 = new JTextField("0");
        txtY1 = new JTextField("0");
        coordPanel1.add(txtX1);
        coordPanel1.add(txtY1);
        inputPanel.add(coordPanel1);

        inputPanel.add(new JLabel("Vertice Inf DX (X, Y):"));
        JPanel coordPanel2 = new JPanel(new GridLayout(1, 2, 5, 5));
        txtX2 = new JTextField("0");
        txtY2 = new JTextField("0");
        coordPanel2.add(txtX2);
        coordPanel2.add(txtY2);
        inputPanel.add(coordPanel2);

        btnCapture = new JButton("Seleziona Area con Mouse (Ombreggiata)");
        inputPanel.add(new JLabel(""));
        inputPanel.add(btnCapture);

        logArea = new JTextArea();
        logArea.setEditable(false);
        JScrollPane scrollPane = new JScrollPane(logArea);

        btnStart = new JButton("AVVIA SCANSIONE");
        btnStart.setFont(new Font("Arial", Font.BOLD, 16));
        btnStart.setBackground(Color.GREEN);

        add(inputPanel, BorderLayout.NORTH);
        add(scrollPane, BorderLayout.CENTER);
        add(btnStart, BorderLayout.SOUTH);

        setupEvents();
    }

    private void setupEvents() {
        btnBrowse.addActionListener(e -> {
            JFileChooser chooser = new JFileChooser();
            chooser.setFileSelectionMode(JFileChooser.DIRECTORIES_ONLY);
            if (chooser.showOpenDialog(this) == JFileChooser.APPROVE_OPTION) {
                txtFilePath.setText(chooser.getSelectedFile().getAbsolutePath());
            }
        });

        btnCapture.addActionListener(e -> {
            logArea.append("Trascina il mouse per selezionare l'area...\n");
            new AreaSelector();
        });

        btnStart.addActionListener(e -> startScanProcess());
    }

    // --- CLASSE PER LA SELEZIONE AREA CON OMBREGGIATURA ---
    private class AreaSelector extends JWindow {
        private Point startPoint;
        private Point currentPoint;

        public AreaSelector() {
            // Finestra trasparente a tutto schermo
            setBackground(new Color(0, 0, 0, 1));
            setSize(Toolkit.getDefaultToolkit().getScreenSize());
            setCursor(new Cursor(Cursor.CROSSHAIR_CURSOR));
            setAlwaysOnTop(true);

            addMouseListener(new MouseAdapter() {
                @Override
                public void mousePressed(MouseEvent e) {
                    startPoint = e.getPoint();
                    currentPoint = startPoint;
                    repaint();
                }

                @Override
                public void mouseReleased(MouseEvent e) {
                    txtX1.setText(String.valueOf(startPoint.x));
                    txtY1.setText(String.valueOf(startPoint.y));
                    txtX2.setText(String.valueOf(e.getX()));
                    txtY2.setText(String.valueOf(e.getY()));
                    dispose();
                }
            });

            addMouseMotionListener(new MouseMotionAdapter() {
                @Override
                public void mouseDragged(MouseEvent e) {
                    currentPoint = e.getPoint();
                    repaint(); // Forza il ridisegno del rettangolo
                }
            });

            setVisible(true);
        }

        @Override
        public void paint(Graphics g) {
            super.paint(g);
            if (startPoint != null && currentPoint != null) {
                Graphics2D g2d = (Graphics2D) g;
                // Colore blu semitrasparente per l'ombreggiatura
                g2d.setColor(new Color(0, 120, 215, 60)); 
                
                int x = Math.min(startPoint.x, currentPoint.x);
                int y = Math.min(startPoint.y, currentPoint.y);
                int width = Math.abs(startPoint.x - currentPoint.x);
                int height = Math.abs(startPoint.y - currentPoint.y);

                g2d.fillRect(x, y, width, height);
                
                // Bordo del rettangolo più marcato
                g2d.setColor(new Color(0, 120, 215));
                g2d.setStroke(new BasicStroke(2));
                g2d.drawRect(x, y, width, height);
            }
        }
    }

    private void startScanProcess() {
        String filePath = txtFilePath.getText();
        String fileName = txtFileName.getText();
        
        int pVal, x1, y1, x2, y2;
        try {
            pVal = Integer.parseInt(txtPages.getText());
            x1 = Integer.parseInt(txtX1.getText());
            y1 = Integer.parseInt(txtY1.getText());
            x2 = Integer.parseInt(txtX2.getText());
            y2 = Integer.parseInt(txtY2.getText());
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this, "Numeri non validi!");
            return;
        }

        final int pages = pVal;
        final int startX = Math.min(x1, x2);
        final int startY = Math.min(y1, y2);
        final int width = Math.abs(x2 - x1);
        final int height = Math.abs(y2 - y1);

        if (width < 10 || height < 10) {
            JOptionPane.showMessageDialog(this, "Area troppo piccola o non valida.");
            return;
        }

        btnStart.setEnabled(false);
        
        SwingWorker<Void, String> worker = new SwingWorker<Void, String>() {
            @Override
            protected Void doInBackground() throws Exception {
                publish("Avvio tra 12 secondi... preparati.");
                
                Robot robot = new Robot();
                XWPFDocument document = new XWPFDocument();
                
                // Margini a zero
                CTSectPr sectPr = document.getDocument().getBody().addNewSectPr();
                CTPageMar pageMar = sectPr.addNewPgMar();
                pageMar.setLeft(BigInteger.ZERO); pageMar.setTop(BigInteger.ZERO);
                pageMar.setRight(BigInteger.ZERO); pageMar.setBottom(BigInteger.ZERO);

                File directory = new File(filePath);
                if (!directory.exists()) directory.mkdirs();
                File printscreenDir = new File(directory, "printscreen");
                if (!printscreenDir.exists()) printscreenDir.mkdirs();
                
                Thread.sleep(12000);

                Rectangle screenRectangle = new Rectangle(startX, startY, width, height);

                for (int i = 0; i < pages; i++) {
                    publish("Cattura pagina " + (i + 1));
                    BufferedImage image = robot.createScreenCapture(screenRectangle);
                    File imgFile = new File(printscreenDir, TimeStamp.timeStamp() + "_p" + (i + 1) + ".jpg");
                    ImageIO.write(image, "jpg", imgFile);

                    robot.mousePress(java.awt.event.InputEvent.BUTTON1_DOWN_MASK);
                    robot.mouseRelease(java.awt.event.InputEvent.BUTTON1_DOWN_MASK);
                    
                    XWPFParagraph paragraph = document.createParagraph();
                    paragraph.setAlignment(org.apache.poi.xwpf.usermodel.ParagraphAlignment.CENTER);
                    XWPFRun run = paragraph.createRun();
                    
                    try (FileInputStream is = new FileInputStream(imgFile)) {
                        run.addPicture(is, XWPFDocument.PICTURE_TYPE_JPEG, imgFile.getName(), 
                                       Units.toEMU(550), Units.toEMU(750));
                    }
                    Thread.sleep(1500);
                }

                try (FileOutputStream out = new FileOutputStream(new File(directory, fileName + ".docx"))) {
                    document.write(out);
                }
                return null;
            }

            @Override protected void process(java.util.List<String> chunks) {
                for (String m : chunks) logArea.append(m + "\n");
            }

            @Override protected void done() {
                logArea.append("COMPLETATO.\n");
                btnStart.setEnabled(true);
                JOptionPane.showMessageDialog(null, "Documento creato in: " + filePath);
            }
        };
        worker.execute();
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new SmartScanGUI().setVisible(true));
    }
}